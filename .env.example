# General Settings
PYTHONPATH=/app/src
SEED=42
DEVICE=cuda

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Demo Configuration
DEMO_HOST=0.0.0.0
DEMO_PORT=7860
API_URL=http://api:8000

# Training Configuration
BATCH_SIZE=16
GRADIENT_ACCUMULATION_STEPS=2
LEARNING_RATE=3.0e-5
NUM_EPOCHS=5
FP16=true

# Data Configuration
MAX_CONTEXT_LEN=512
MAX_QUESTION_LEN=48
MAX_ANSWER_LEN=15

# Dataset Size Limiting (set to 0 for full dataset)
TRAIN_LIMIT=0
VAL_LIMIT=0
TEST_LIMIT=0

# Generation Configuration
NUM_BEAMS=6
LENGTH_PENALTY=1.1
NO_REPEAT_NGRAM_SIZE=3
MAX_NEW_TOKENS=50

# Evaluation Configuration
QA_F1_THRESHOLD=0.8
QA_CONF_THRESHOLD=0.35

# Weights & Biases
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=wh-question-generation
WANDB_ENTITY=your_wandb_entity_here
WANDB_MODE=offline

# Directories
CHECKPOINT_DIR=/app/checkpoints
DATA_DIR=/app/data
LOGS_DIR=/app/logs

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
